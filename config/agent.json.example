# AI Agent 配置示例
# 复制此文件为 agent.json 并填入真实的 API Key
# 支持 OpenAI 兼容 API（千问、DeepSeek、GPT 等）

{
  "llm": {
    "model_id": "qwen-plus",
    "api_key": "YOUR_LLM_API_KEY_HERE",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1"
  },
  "vision": {
    "model_id": "qwen-vl-max",
    "api_key": "YOUR_VISION_API_KEY_HERE",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1"
  },
  "embedding": {
    "model_name": "text-embedding-v3",
    "api_key": "YOUR_EMBEDDING_API_KEY_HERE",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1"
  },
  "settings": {
    "max_questions_per_image": 10,
    "max_questions_per_document": 50,
    "confidence_threshold": 0.6,
    "max_file_size_mb": 50,
    "http_proxy": null
  },
  "allowed_extensions": {
    "images": [
      "png",
      "jpg",
      "jpeg",
      "gif",
      "webp"
    ],
    "documents": [
      "pdf",
      "doc",
      "docx",
      "txt",
      "md"
    ]
  }
}
